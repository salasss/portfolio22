# Copie ce fichier en .env et renseigne tes valeurs.

# Endpoint du formulaire de contact (Formspree ou Web3Forms).
# Ex Formspree : https://formspree.io/f/xxxxxx
# Laisse vide -> le formulaire bascule automatiquement sur un fallback mailto:
VITE_CONTACT_ENDPOINT=

# Domaine analytics privacy-first (Plausible). Laisse vide pour désactiver.
# Ex : salas-alkama.dev
VITE_PLAUSIBLE_DOMAIN=
